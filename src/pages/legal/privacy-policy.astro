---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Privacy Policy">
  <div class="container mx-auto px-4 max-w-2xl pt-24 pb-16">
    <h1 class="mb-8 text-center font-bold text-4xl">Privacy Policy</h1>
    <div class="prose dark:prose-invert max-w-none">
      <p>This is the placeholder page for your privacy policy. Update this page with your actual privacy policy content.</p>
    </div>
  </div>
</MarketingLayout>
