---
import MarketingLayout from '../layouts/MarketingLayout.astro';
---

<MarketingLayout title="Download MakerVault" description="Download MakerVault for macOS. 7-day free trial, no credit card required.">
  <div class="container mx-auto px-4 max-w-2xl pt-24 pb-16">
    <div class="pt-8 text-center">
      <h1 class="mb-2 font-bold text-5xl">Download MakerVault</h1>
      <p class="text-balance text-lg opacity-50">
        7-day free trial, no credit card required.
      </p>
    </div>

    <div class="mt-12 rounded-2xl border bg-card p-8 text-center">
      <div class="flex items-center justify-center gap-2 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"/><path d="M10 2c1 .5 2 2 2 5"/></svg>
        <h2 class="text-2xl font-semibold">macOS</h2>
      </div>
      <p class="text-sm text-foreground/50 mb-6">
        macOS 12 (Monterey) or later &middot; Apple Silicon (M1/M2/M3/M4)
      </p>
      <a
        href="https://github.com/zeekpardo/makervault/releases/latest/download/MakerVault_0.1.0_aarch64.dmg"
        class="inline-flex items-center justify-center rounded-md bg-primary px-8 py-3 font-medium text-primary-foreground text-sm hover:bg-primary/90 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 size-4"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
        Download for macOS
      </a>
      <p class="mt-3 text-xs text-foreground/40">
        One-time purchase of $59. Includes 1 year of updates. Keep the app forever.
      </p>
    </div>

    <div class="mt-8 rounded-2xl border border-dashed bg-muted/30 p-8 text-center">
      <div class="flex items-center justify-center gap-2 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6 text-foreground/40"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
        <h2 class="text-2xl font-semibold text-foreground/50">Windows</h2>
      </div>
      <p class="text-sm text-foreground/50 mb-6">
        Coming soon. Sign up to be notified when it launches.
      </p>
      <iframe
        src="https://link.groovi.pro/widget/form/xfMUejfCkBNxUMhinucW"
        style="width:100%;height:407px;border:none;border-radius:3px"
        id="inline-xfMUejfCkBNxUMhinucW"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="MakerVault - subscribe"
        data-height="407"
        data-layout-iframe-id="inline-xfMUejfCkBNxUMhinucW"
        data-form-id="xfMUejfCkBNxUMhinucW"
        title="MakerVault - subscribe"
      ></iframe>
    </div>

    <div class="mt-12 space-y-4 text-sm text-foreground/50">
      <h3 class="font-semibold text-foreground text-base">Installation</h3>
      <ol class="list-decimal list-inside space-y-2">
        <li>Open the downloaded <code>.dmg</code> file</li>
        <li>Drag <strong>MakerVault</strong> to your Applications folder</li>
        <li>Open MakerVault from Applications</li>
        <li>If macOS shows a security warning, go to <strong>System Settings → Privacy & Security</strong> and click <strong>Open Anyway</strong></li>
      </ol>
    </div>
  </div>
  <script is:inline src="https://link.groovi.pro/js/form_embed.js"></script>
</MarketingLayout>
