---
import MarketingLayout from '../layouts/MarketingLayout.astro';

// Fetch latest published release from GitHub API at build time
// Use actual asset URLs to avoid tag/filename mismatch 404s
let version = '0.2.0';
let macDmg = '';
let winExe = '';
try {
  const res = await fetch('https://api.github.com/repos/zeekpardo/makervault/releases/latest');
  if (res.ok) {
    const data = await res.json();
    version = data.tag_name.replace(/^v/, '');
    for (const asset of data.assets) {
      const name = asset.name.toLowerCase();
      if (name.endsWith('.dmg')) macDmg = asset.browser_download_url;
      if (name.endsWith('.exe') && name.includes('setup')) winExe = asset.browser_download_url;
    }
  }
} catch {}
// Fallback if API didn't return assets
if (!macDmg) macDmg = `https://github.com/zeekpardo/makervault/releases/download/v${version}/MakerVault_${version}_universal.dmg`;
if (!winExe) winExe = `https://github.com/zeekpardo/makervault/releases/download/v${version}/MakerVault_${version}_x64-setup.exe`;
---

<MarketingLayout title="Download MakerVault" description="Download MakerVault for macOS and Windows. 7-day free trial, no credit card required.">
  <div class="container mx-auto px-4 max-w-2xl pt-24 pb-16">
    <div class="pt-8 text-center">
      <h1 class="mb-2 font-bold text-5xl">Download MakerVault</h1>
      <p class="text-balance text-lg opacity-50">
        7-day free trial, no credit card required.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      <!-- macOS -->
      <div class="rounded-2xl border bg-card p-8 text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6"><path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"/><path d="M10 2c1 .5 2 2 2 5"/></svg>
          <h2 class="text-2xl font-semibold">macOS</h2>
        </div>
        <p class="text-xs text-foreground/50 mb-6">
          macOS 12+ &middot; Intel &amp; Apple Silicon
        </p>
        <a
          href={macDmg}
          class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-primary-foreground text-sm hover:bg-primary/90 transition-colors w-full"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 size-4"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          Download .dmg
        </a>
        <p class="mt-2 text-xs text-foreground/30">v{version} &middot; Universal</p>
      </div>

      <!-- Windows -->
      <div class="rounded-2xl border bg-card p-8 text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-6"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
          <h2 class="text-2xl font-semibold">Windows</h2>
        </div>
        <p class="text-xs text-foreground/50 mb-6">
          Windows 10+ &middot; 64-bit
        </p>
        <a
          href={winExe}
          class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-primary-foreground text-sm hover:bg-primary/90 transition-colors w-full"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 size-4"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          Download .exe
        </a>
        <p class="mt-2 text-xs text-foreground/30">v{version} &middot; 64-bit</p>
      </div>
    </div>

    <p class="mt-4 text-center text-xs text-foreground/40">
      One-time purchase of $59. Includes 1 year of updates. Keep the app forever.
      <br />
      <a href="/releases" class="underline hover:text-foreground/60">
        View past releases
      </a>
    </p>

    <div class="mt-12 grid gap-8 sm:grid-cols-2">
      <div class="space-y-3 text-sm text-foreground/50">
        <h3 class="font-semibold text-foreground text-base">macOS Installation</h3>
        <ol class="list-decimal list-inside space-y-2">
          <li>Open the downloaded <code>.dmg</code> file</li>
          <li>Drag <strong>MakerVault</strong> to Applications</li>
          <li>Open MakerVault from Applications</li>
          <li>If macOS shows a security warning, go to <strong>System Settings &rarr; Privacy &amp; Security</strong> and click <strong>Open Anyway</strong></li>
        </ol>
      </div>

      <div class="space-y-3 text-sm text-foreground/50">
        <h3 class="font-semibold text-foreground text-base">Windows Installation</h3>
        <ol class="list-decimal list-inside space-y-2">
          <li>Run the downloaded <code>.exe</code> installer</li>
          <li>Follow the installation wizard</li>
          <li>Launch MakerVault from the Start Menu</li>
          <li>If Windows shows a SmartScreen warning, click <strong>More info</strong> then <strong>Run anyway</strong></li>
        </ol>
      </div>
    </div>

    <div class="mt-12 rounded-2xl border border-dashed bg-muted/30 p-8 text-center">
      <h3 class="text-lg font-semibold mb-2">Stay in the loop</h3>
      <p class="text-sm text-foreground/50 mb-4">
        Get notified about new releases, features, and tips for organizing your design files.
      </p>
      <iframe
        src="https://link.groovi.pro/widget/form/xfMUejfCkBNxUMhinucW"
        style="width:100%;height:407px;border:none;border-radius:3px"
        id="inline-xfMUejfCkBNxUMhinucW"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="MakerVault - subscribe"
        data-height="407"
        data-layout-iframe-id="inline-xfMUejfCkBNxUMhinucW"
        data-form-id="xfMUejfCkBNxUMhinucW"
        title="MakerVault - subscribe"
      ></iframe>
    </div>
  </div>
  <script is:inline src="https://link.groovi.pro/js/form_embed.js"></script>
</MarketingLayout>
