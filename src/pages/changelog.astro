---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const entries = [
  {
    date: "2026-03-07",
    title: "File Management & Filtering",
    changes: [
      "Delete files — move duplicates to system Trash from the Duplicates view",
      "Rename files — right-click any file to rename it on disk",
      "Hide Fonts filter — exclude font files from your main file list",
      "Ignore duplicate groups — dismiss intentional duplicates from the list",
      "Exclude categories filter for hiding unwanted file types",
    ],
  },
  {
    date: "2026-02-20",
    title: "Auto-Updates & Licensing",
    changes: [
      "Auto-updater with license-gated update notifications",
      "Switched to LemonSqueezy for payment processing",
      "Updates expiration tracking with renewal flow",
      "7-day free trial (reduced from 14 days)",
      "App icons and icon generation script",
    ],
  },
  {
    date: "2026-02-05",
    title: "Tags & Sources",
    changes: [
      "Colored tag badges in file list for visual organization",
      "Nested tag picker with two-step add flow",
      "Source quick-create from pasted URLs",
      "Sidebar simplification and UI improvements",
    ],
  },
  {
    date: "2026-01-20",
    title: "File Linking & Detail Panel",
    changes: [
      "Bidirectional file linking with relationship types (derived from, variant, export, reference)",
      "LightBurn font auto-linking — automatically links font files used in designs",
      "Inline preview in detail panel for previewable files",
      "Expandable file rows with 3-column layout",
      "Windows support groundwork",
    ],
  },
  {
    date: "2026-01-05",
    title: "Initial Release",
    changes: [
      "Full-text search with deep search (/ prefix) for searching inside file contents",
      "Hierarchical tagging with nested tags up to 3 levels deep",
      "Spacebar quick preview for SVG, images, PDF, fonts, and LightBurn files",
      "LightBurn metadata extraction (cut settings, notes, fonts, text elements)",
      "Real-time file watching with automatic indexing of 25+ file types",
      "Duplicate detection with BLAKE3 content hashing",
      "Source tracking with auto-detection from URLs",
      "Multi-filter system combining file type, tags, sources, favorites, and notes",
    ],
  },
];

function timeAgo(dateStr: string) {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  if (days < 30) return `${days} days ago`;
  const months = Math.floor(days / 30);
  if (months < 12) return `${months} month${months > 1 ? 's' : ''} ago`;
  const years = Math.floor(months / 12);
  return `${years} year${years > 1 ? 's' : ''} ago`;
}
---

<MarketingLayout title="Changelog" description="Stay up to date with the latest changes in MakerVault.">
  <div class="container mx-auto px-4 max-w-3xl pt-24 pb-16">
    <div class="mb-12 text-balance pt-8 text-center">
      <h1 class="mb-2 font-bold text-5xl">Changelog</h1>
      <p class="text-lg opacity-50">
        Stay up to date with the latest changes in our product.
      </p>
    </div>

    <div class="mx-auto max-w-xl grid gap-6">
      {entries.map((entry) => (
        <div class="rounded-3xl bg-muted p-6 lg:p-8">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-xl font-semibold">{entry.title}</h2>
            <span class="uppercase text-primary text-xs font-medium" title={entry.date}>
              {timeAgo(entry.date)}
            </span>
          </div>
          <ul class="list-disc pl-6 text-foreground/60 text-sm space-y-1">
            {entry.changes.map((change) => (
              <li>{change}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</MarketingLayout>
